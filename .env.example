# TerraScan Environment Configuration
# Copy this file to .env and fill in your values

# Server Port
PORT=3000

# MongoDB Connection String
# Use your local URI or a MongoDB Atlas URI for cloud access
# Example (Local): mongodb://127.0.0.1:27017/terrascan
# Example (Atlas): mongodb+srv://<username>:<password>@cluster.mongodb.net/terrascan
MONGODB_URI=mongodb://127.0.0.1:27017/terrascan

# Security
SESSION_SECRET=your_super_secret_key_here

# Social Login (Optional)
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret
FACEBOOK_APP_ID=your_facebook_id
FACEBOOK_APP_SECRET=your_facebook_secret

# AI Assistant (Optional)
OPENROUTER_API_KEY=your_openrouter_api_key
